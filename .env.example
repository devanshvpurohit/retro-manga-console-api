# Retro Manga Console API Configuration

# Optional: API token protection
API_TOKEN=your_secret_token_here

# Optional: Enable NSFW filtering (true/false)
NSFW_FILTER=false

# Optional: Default manga source
DEFAULT_SOURCE=mangataro

# Optional: Rate limiting (requests per minute)
RATE_LIMIT=60

# Optional: Image compression quality (1-100)
IMAGE_QUALITY=40

# Optional: Target display dimensions
DISPLAY_WIDTH=320
DISPLAY_HEIGHT=240

# Optional: Enable grayscale mode
GRAYSCALE_MODE=true

# Optional: Cache TTL in seconds
CACHE_TTL=300
